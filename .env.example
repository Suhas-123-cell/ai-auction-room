# AI Auction Room — single .env for both backend and frontend
# Copy to .env and fill in real values

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # backend only (never expose to browser)
SUPABASE_JWT_SECRET=your-jwt-secret          # backend only

# ── Groq ──────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key

# ── Frontend (Vite reads VITE_ vars from this file) ───────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key         # public key, safe to expose

VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_AUCTION_TIMER=30

# ── Backend misc ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Single-service deployment (Render) ───────────────────────────────
# Set VITE_* vars in Render dashboard BEFORE the build runs.
# They are baked into the JS bundle at build time.
# Leave VITE_API_URL empty so the frontend uses the same origin as the backend.
FRONTEND_URL=https://your-app.onrender.com
